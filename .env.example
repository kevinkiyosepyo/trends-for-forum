# ── LLM ────────────────────────────────────────────────
# Provider: "openai" or "anthropic"
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Forum Market API ────────────────────────────────────
# Get these from app.forum.market → API settings
FORUM_API_KEY=
FORUM_API_SECRET=
FORUM_BASE_URL=https://api.forum.market/v1

# ── Optional ────────────────────────────────────────────
NEWS_API_KEY=
SERPAPI_API_KEY=
